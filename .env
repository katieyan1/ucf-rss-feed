# TradeDecider execution mode: visualize or live
TRADE_DECIDER_MODE=visualize

# Kalshi API endpoint configuration
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_ORDER_PATH=/portfolio/orders
KALSHI_ORDER_TIMEOUT_SECONDS=10

# Auth option A: bearer token
KALSHI_API_TOKEN=

# Auth option B: signed key pair
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY_PASSPHRASE=

# Optional JSON object of extra headers, for example:
# KALSHI_EXTRA_HEADERS={"X-My-Header":"value"}
KALSHI_EXTRA_HEADERS={}
